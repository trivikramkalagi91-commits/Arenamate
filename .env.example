# ArenaMate Configuration Example
# Copy this file to .env and configure as needed.

# Application settings
APP_NAME=ArenaMate

# Gemini settings (optional - if omitted, ArenaMate uses a Mock LLM offline)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_OUTPUT_TOKENS=256

# CORS configuration (JSON array of allowed origins)
ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# Rate limiting settings (token bucket per IP)
RATE_LIMIT_CAPACITY=30
RATE_LIMIT_REFILL_PER_SEC=0.5
